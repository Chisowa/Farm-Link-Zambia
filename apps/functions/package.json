{
  "name": "@repo/functions",
  "private": true,
  "version": "0.0.0",
  "main": "lib/index.js",
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/trpc/router.ts"
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "tsc --watch",
    "dev:server": "tsx --watch src/dev-server.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "@google-cloud/vertexai": "^1.4.0",
    "@trpc/server": "^11.0.0-rc.660",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^6.0.0",
    "google-auth-library": "^9.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/shared": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "tsx": "^4.19.2",
    "typescript": "5.5.4",
    "vitest": "^2.1.8"
  }
