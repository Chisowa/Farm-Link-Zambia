# ── Firebase Admin SDK ────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate new private key → download JSON → copy values below
FIREBASE_PROJECT_ID=farmlink-zambia
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-XXXXX@farmlink-zambia.iam.gserviceaccount.com

# ── Google Cloud / Vertex AI ──────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=farmlink-zambia
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL_ID=gemini-2.0-flash-001

# ── GCS Bucket (agricultural document storage) ────────────────────────────────
GCS_BUCKET=famlinkdocs

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Firebase Emulators (uncomment for local development) ──────────────────────
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIRESTORE_EMULATOR_HOST=localhost:8080
