{
  "name": "@repo/functions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "firestore:check": "NODE_OPTIONS='--loader ts-node/esm' npx ts-node src/scripts/check-firestore.ts",
    "firestore:init": "NODE_OPTIONS='--loader ts-node/esm' npx ts-node src/scripts/firestore-init.ts"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.4.0",
    "@repo/shared": "workspace:*",
    "@trpc/server": "^11.0.0-rc.660",
    "firebase-admin": "^12.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.2",
    "typescript": "5.5.4",
    "vitest": "^2.1.8"
  }
}
