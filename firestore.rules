rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read and write their own documents
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Any authenticated user can read reference data
    match /crops/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /pests/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /diseases/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /weatherData/{document=**} {
      allow read: if request.auth != null;
    }
    
    match /marketPrices/{document=**} {
      allow read: if request.auth != null;
    }

    // Users can create and read their own advice
    match /advice/{document=**} {
      allow read, create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth.uid == resource.data.userId;
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}